---
import "../styles/global.css";
import Nav from "../components/Nav";
import EditorUnlock from "../components/EditorUnlock";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href={`${import.meta.env.BASE_URL}${import.meta.env.PUBLIC_STATIC_DATA === "true" ? "favicon.png" : "favicon-local.png"}`} />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}${import.meta.env.PUBLIC_STATIC_DATA === "true" ? "favicon.svg" : "favicon-local.svg"}`} />
    <link rel="alternate icon" type="image/x-icon" href={`${import.meta.env.BASE_URL}favicon.ico`} />
    <link rel="apple-touch-icon" href={`${import.meta.env.BASE_URL}apple-touch-icon.png`} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Claire — Cultural Dispatch</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500&family=Playfair+Display:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-white min-h-screen">
    <EditorUnlock client:load />
    <Nav current="" client:load />
    <main class="max-w-2xl mx-auto px-4 pt-20 pb-24 md:pb-8">
      <p class="font-serif text-2xl text-neutral-900 mt-4 mb-8">Claire</p>
      <div class="space-y-5 text-sm text-neutral-700 leading-relaxed">
        <p>You know who I am.</p>
      </div>
      <div class="mt-12 pt-8 border-t border-neutral-100 flex items-center justify-center">
        <span class="font-serif text-2xl text-neutral-200 select-none">⁂</span>
      </div>
    </main>
  </body>
</html>
