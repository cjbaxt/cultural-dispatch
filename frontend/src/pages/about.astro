---
import "../styles/global.css";
import Nav from "../components/Nav";
import EditorUnlock from "../components/EditorUnlock";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href={`${import.meta.env.BASE_URL}favicon.png`} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>About — cultural dispatch</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500&family=Playfair+Display:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-white min-h-screen">
    <EditorUnlock client:load />
    <Nav current="/about" client:load />
    <main class="max-w-2xl mx-auto px-4 pt-20 pb-24 md:pb-8">
      <h1 class="font-serif text-3xl font-medium mb-6">About</h1>
      <div class="prose prose-neutral text-neutral-700 leading-relaxed space-y-4">
        <p>Writing about art, performance, and the experience of being in a room where something happens.</p>
      </div>
    </main>
  </body>
</html>
